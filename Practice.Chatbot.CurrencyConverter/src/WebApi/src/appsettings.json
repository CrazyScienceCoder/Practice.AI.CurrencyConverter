{
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.OpenSearch"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Information",
        "System": "Warning",
        "Microsoft.Extensions.AI": "Warning"
      }
    },
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithThreadId",
      "WithProcessId"
    ],
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "OpenSearch",
        "Args": {
          "nodeUris": "%OPENSEARCH_NODE_URIS%",
          "indexFormat": "ai-agent-api-{0:HOSTNAME}",
          "autoRegisterTemplate": true,
          "numberOfShards": 1,
          "numberOfReplicas": 0
        }
      }
    ]
  },
  "Keycloak": {
    "Authority": "http://localhost:8080/realms/currency-converter",
    "Audience": "ai-agent-api",
    "RequireHttpsMetadata": "false"
  },
  "Redis": {
    "ConnectionString": "localhost:6379",
    "InstanceName": "ChatBot"
  },
  "CurrencyConverterClient": {
    "BaseUrl": "http://localhost:5263",
    "ApiVersion": "1.0"
  },
  "AI": {
    "Provider": "Ollama",
    "ModelId": "lfm2.5-thinking",
    "Ollama": {
      "Endpoint": "http://localhost:11434"
    },
    "OpenAI": {
      "ApiKey": ""
    },
    "Gemini": {
      "ApiKey": "",
      "ModelId": "gemini-1.5-flash",
      "Endpoint": "https://generativelanguage.googleapis.com/v1beta/openai/"
    }
  }
}
